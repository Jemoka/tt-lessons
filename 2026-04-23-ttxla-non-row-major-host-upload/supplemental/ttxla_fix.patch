 namespace tt::pjrt {
 
+namespace {
+
+std::vector<std::uint32_t>
+calculateDenseRowMajorStrides(const std::vector<std::uint32_t> &shape) {
+  std::vector<std::uint32_t> strides(shape.size(), 1);
+  std::uint64_t running_stride = 1;
+  for (std::size_t i = shape.size(); i-- > 0;) {
+    strides[i] = static_cast<std::uint32_t>(running_stride);
+    running_stride *= shape[i];
+  }
+  return strides;
+}
+
+std::vector<std::byte>
+materializeDenseRowMajorBuffer(const void *host_buffer,
+                               const std::vector<std::uint32_t> &shape,
+                               const std::vector<std::uint32_t> &src_strides,
+                               std::uint32_t element_size) {
+  std::uint64_t num_elements = std::accumulate(
+      shape.begin(), shape.end(), std::uint64_t{1}, std::multiplies<>());
+  std::vector<std::byte> dense_buffer(num_elements * element_size);
+
+  if (host_buffer == nullptr || num_elements == 0) {
+    return dense_buffer;
+  }
+
+  const std::vector<std::uint32_t> dense_strides =
+      calculateDenseRowMajorStrides(shape);
+  const std::byte *src = static_cast<const std::byte *>(host_buffer);
+
+  for (std::uint64_t linear_index = 0; linear_index < num_elements;
+       ++linear_index) {
+    std::uint64_t remainder = linear_index;
+    std::uint64_t src_linear_index = 0;
+    for (std::size_t dim = 0; dim < shape.size(); ++dim) {
+      const std::uint64_t coord = remainder / dense_strides[dim];
+      remainder %= dense_strides[dim];
+      src_linear_index += coord * src_strides[dim];
+    }
+
+    std::memcpy(dense_buffer.data() + linear_index * element_size,
+                src + src_linear_index * element_size, element_size);
+  }
+
+  return dense_buffer;
+}
+
